# ── Zoho Web-to-Lead ──────────────────────────────────────────────────────────
# Action URL from your Zoho CRM Web-to-Lead form settings
ZOHO_WEBTOLEAD_ACTION_URL=

# Hidden auth tokens copied from Zoho's generated form HTML
ZOHO_XNQSJSDP=
ZOHO_XMIWTLD=

# Base64-encoded module name ("TGVhZHM=" = "Leads")
ZOHO_ACTIONTYPE=TGVhZHM=

# Where Zoho redirects after a successful submission (our thank-you page)
ZOHO_RETURNURL=https://spperera.me/start-project/thank-you

# The URL Zoho expects as the HTTP Referer header (must match your form's origin)
ZOHO_FORM_LOCATION_URL=https://spperera.me/start-project

# Zoho field that receives the budget picklist value (default: Salutation)
ZOHO_FIELD_BUDGET=Salutation

# ── Zoho SMTP (fallback lead email) ───────────────────────────────────────────
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=                 # your Zoho Mail address, e.g. you@yourdomain.com
ZOHO_SMTP_PASS=                 # Zoho Mail → Settings → Security → App Passwords

# Email address that receives lead alert emails
LEAD_NOTIFY_EMAIL=

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Create a site at dash.cloudflare.com → Turnstile → Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=   # exposed to the browser (safe)
TURNSTILE_SECRET_KEY=             # server-only — never commit

# ── Scheduler embed ───────────────────────────────────────────────────────────
# iframe src for the booking widget on the thank-you page
# e.g. https://calendly.com/yourname/30min or a Zoho Bookings embed URL
NEXT_PUBLIC_SCHEDULER_URL=
